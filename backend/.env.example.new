# ============================================
# BACKEND ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git!
# Add .env to .gitignore if not already there

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server listening port (default: 5000)
PORT=5000

# Environment: development, staging, or production
NODE_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection - Choose ONE option:

# Option 1: Individual connection parameters
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_pdf_db
DB_DEBUG=false

# Option 2: Connection URL (takes precedence over individual params)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# API KEYS & SECRETS (SENSITIVE - NEVER COMMIT)
# ============================================
# Groq API Key - Required for AI features
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key - Optional, for fallback AI
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# GitHub API token - Optional, increases rate limits for profile analysis
GITHUB_TOKEN=your_github_token_here

# ============================================
# SERVICE URLs
# ============================================
# Backend's own public URL (used by other services to call back)
BACKEND_URL=http://localhost:5000
PUBLIC_API_URL=http://localhost:5000

# RAG/PDF Service URL
RAG_SERVICE_URL=http://localhost:5001

# RPC Service URL
RPC_SERVICE_URL=http://localhost:3333

# GitHub API base URL
GITHUB_API_BASE_URL=https://api.github.com

# ============================================
# CORS CONFIGURATION
# ============================================
# Primary CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# Additional allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# AI MODEL CONFIGURATION
# ============================================
# Primary Groq model
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile

# Fallback Groq model
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# OpenAI model for chat
OPENAI_MODEL=gpt-4o-mini

# ============================================
# TOKEN BUDGET CONFIGURATION (AI)
# ============================================
# Base token budget for content generation
TOKEN_BASE_BUDGET=3200

# Token budget for individual lessons
TOKEN_LESSON_DEFAULT=3000
TOKEN_LESSON_MAX=8192

# Token budget for course outlines
TOKEN_OUTLINE_DEFAULT=900
TOKEN_OUTLINE_MAX=2000

# Global maximum tokens
TOKEN_GLOBAL_MAX=8192

# Fallback model maximum tokens
TOKEN_FALLBACK_MAX=2048

# ============================================
# TIMEOUT CONFIGURATION (milliseconds)
# ============================================
# Standard API timeout
TIMEOUT_API_STANDARD=5000

# RAG operation timeout (PDF retrieval, etc.)
TIMEOUT_RAG_OPERATION=90000

# Validation/tooling timeout
TIMEOUT_VALIDATION=30000

# Retry delay
RETRY_DELAY=1000

# Rate limit wait time
RATE_LIMIT_WAIT=3000

# ============================================
# CACHING CONFIGURATION
# ============================================
# RAG response cache TTL (5 minutes)
CACHE_RAG_TTL=300000

# PDF chat cache TTL (20 seconds)
CACHE_PDF_TTL=20000

# Cache cleanup interval (60 seconds)
CACHE_CLEANUP_INTERVAL=60000

# Maximum cache entries
CACHE_MAX_SIZE=100

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Directory for uploaded files
UPLOADS_DIR=./uploads

# Maximum upload file size (bytes)
MAX_UPLOAD_SIZE=52428800

# ============================================
# FEATURE FLAGS
# ============================================
# Enable Groq AI features
FEATURE_USE_GROQ=true

# Enable OpenAI features
FEATURE_USE_OPENAI=true

# Enable RAG response caching
FEATURE_RAG_CACHE=true

# Enable PDF mindmap generation
FEATURE_PDF_MINDMAP=true

# ============================================
# LEARNING CONFIGURATION
# ============================================
# Default number of lessons per course
DEFAULT_LESSON_COUNT=5

# Maximum number of lessons
GROQ_LESSON_COUNT=5

# Lesson maximum tokens
GROQ_LESSON_MAX_TOKENS=3000

# Learning maximum tokens
GROQ_LEARNING_MAX_TOKENS=8192

# Outline maximum tokens
GROQ_OUTLINE_MAX_TOKENS=900

# ============================================
# VALIDATION LIMITS
# ============================================
# Maximum message length (characters)
MAX_MESSAGE_LENGTH=2000

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
# Include sources in RAG responses
INCLUDE_SOURCES=true

# RAG service port (for multi-service setup)
RAG_PORT=5001
