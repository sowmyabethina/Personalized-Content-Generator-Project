# Copy to .env and fill in values. Never commit real secrets.

# Server
PORT=5000
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PUBLIC_API_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
UPLOADS_DIR=./uploads

# Database (use one style)
DATABASE_URL=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_NAME=rag_pdf_db
DB_PORT=5432

# AI
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_LEARNING_MAX_TOKENS=3200
GROQ_LESSON_MAX_TOKENS=3000
GROQ_OUTLINE_MAX_TOKENS=900
GROQ_LESSON_COUNT=5
GROQ_FALLBACK_MAX_TOKENS=2048

GEMINI_API_KEY=
OPENAI_API_KEY=

# RAG PDF service (separate service)
RAG_SERVICE_URL=http://localhost:5001
