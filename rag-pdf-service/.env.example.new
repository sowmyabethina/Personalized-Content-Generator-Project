# ============================================
# RAG PDF SERVICE ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git!

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server listening port (default: 5001)
PORT=5001

# Environment: development, staging, or production
NODE_ENV=development

# ============================================
# API KEYS & SECRETS (SENSITIVE - NEVER COMMIT)
# ============================================
# Groq API Key - Required
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# CORS CONFIGURATION
# ============================================
# Allow all origins by default (production: specify domain)
CORS_ORIGIN=true

# ============================================
# CACHING CONFIGURATION
# ============================================
# Cache TTL for PDF chat responses (milliseconds)
CACHE_TTL=20000

# Cache cleanup interval (milliseconds)
CACHE_CLEANUP_INTERVAL=60000

# ============================================
# RAG/PDF PROCESSING
# ============================================
# Include source references in responses
INCLUDE_SOURCES=true

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
# Debug logging
DEBUG=false
